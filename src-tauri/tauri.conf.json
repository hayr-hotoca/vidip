{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vidip",
  "version": "1.0.0",
  "identifier": "com.hahoto.compress-slipt-trim-merge-videos-app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vidip",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/ffmpeg-aarch64-apple-darwin"
    ]
  }
}
